generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  customer
  manager
  admin
}

enum Gender {
  men
  women
  unisex
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum PaymentMethod {
  cod
  payfast
}

enum PaymentStatus {
  unpaid
  paid
  refunded
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String?
  phone           String?
  avatarUrl       String?
  role            Role     @default(customer)
  newsletterOptIn Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts      Account[]
  refreshTokens RefreshToken[]
  addresses     Address[]
  cart          Cart?
  orders        Order[]
}

model Account {
  id                String  @id @default(uuid())
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  idToken           String?
  expiresAt         Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Address {
  id         String  @id @default(uuid())
  label      String  @default("Home")
  street     String
  city       String
  state      String
  postalCode String
  country    String
  isDefault  Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  image     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String
  price         Float
  discountPrice Float?
  images        String[] // base product images shown when no variant is selected
  stock         Int      @default(0) // total fallback — used only when no variants exist
  isFeatured    Boolean  @default(false)
  gender        Gender   @default(unisex)
  tags          String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants   ProductVariant[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([gender])
  @@index([isFeatured])
}

model ProductVariant {
  id            String   @id @default(uuid())
  color         String? // display name e.g. "Midnight Black"
  colorHex      String? // hex code e.g. "#1A1A1A" — drives colour swatch UI
  size          String? // e.g. "Small", "Medium", "Large" — null for products with no size
  sku           String?  @unique
  stock         Int      @default(0)
  priceOverride Float? // null = inherit product.price; set = variant has its own price
  images        String[] // variant-specific images; falls back to product.images if empty

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, color, size]) // prevents duplicate colour+size combos on one product
  @@index([productId])
}

model Cart {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String     @unique
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]
}

model CartItem {
  id       String @id @default(uuid())
  quantity Int    @default(1)

  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // null = no variant selected (product has no variants)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  // Unique per cart+product+variant combination so the same product in two
  // different colours creates two separate cart rows, not one merged row
  @@unique([cartId, productId, variantId])
}

model Order {
  id              String        @id @default(uuid())
  totalAmount     Float
  status          OrderStatus   @default(pending)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(unpaid)
  shippingAddress Json
  trackingNumber  String?
  payfastToken    String?
  merchantRef     String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  userId String
  user   User         @relation(fields: [userId], references: [id])
  items  OrderItem[]
  events OrderEvent[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id       String  @id @default(uuid())
  name     String // product name snapshot
  price    Float // effective price snapshot at time of order
  quantity Int
  image    String  @default("")
  // variant snapshots — preserved even if the variant is later deleted
  color    String?
  size     String?
  sku      String?

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  // null = order placed for a product with no variants
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
}

model OrderEvent {
  id        String      @id @default(uuid())
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}
